# =============================================================================
# RAG Eval Lab — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in your values:
#   cp .env.example .env
#
# .env is gitignored — never commit real secrets.
# =============================================================================

# ── NVIDIA API (for LLM generation) ─────────────────────────────────────────
# Get a free key at: https://build.nvidia.com
# The NVIDIA API is 100% OpenAI-compatible — same SDK, different base_url.
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_MODEL=nvidia/llama-3.1-nemotron-nano-8b-instruct

# ── Qdrant (Vector Database — local Docker) ──────────────────────────────────
# Start Qdrant:  docker run -p 6333:6333 -p 6334:6334 qdrant/qdrant
# 6333 = REST API   |   6334 = gRPC
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=rag_eval_lab


# ── Ollama (Embeddings — local) ──────────────────────────────────────────────
# Start Ollama:  ollama serve
# Pull model:    ollama pull bge-small-en-v1.5
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=bge-small-en-v1.5
EMBED_DIM=384
# ── Langfuse (Tracing — self-hosted Docker) ───────────────────────────────────
# Start Langfuse:  docker compose -f docker-compose.langfuse.yml up -d
# Then open:       http://localhost:3000  → create project → copy keys below
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_HOST=http://localhost:3000

# ── Cohere & HuggingFace (optional — for rerankers and unthrottled downloads) ──
# COHERE_API_KEY=your-cohere-key-here
# HF_TOKEN=your-huggingface-token-here

LOG_LEVEL=INFO
EXPERIMENT_CONFIG_PATH=app/config/experiment.yaml